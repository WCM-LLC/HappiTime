{
  "expo": {
    "name": "HappiTime",
    "slug": "happyhour-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "happitime",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0EB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      ["expo-apple-authentication"],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "",
          "googleMapsEnabled": false
        }
      ],
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "HappiTime uses your location to show happy hours near you.",
          "locationWhenInUsePermission": "HappiTime uses your location to show happy hours near you."
        }
      ]
    ],
    "ios": {
      "usesAppleSignIn": true,
      "supportsTablet": true,
      "bundleIdentifier": "com.jwill7486.happitime.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "HappiTime uses your location to show happy hours near you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "HappiTime uses your location to show happy hours near you even when the app is in the background.",
        "CFBundleAllowMixedLocalizations": true
      },
      "config": {
        "googleMapsApiKey": ""
      }
    },
    "android": {
      "package": "com.jwill7486.happitime.mobile",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C8965A"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "eas": {
        "projectId": "11746dbf-de7c-408d-80c3-45859e657550"
      }
    },
    "owner": "jwill7486",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/11746dbf-de7c-408d-80c3-45859e657550"
    }
  }
}
