{
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "jsx": "react-native",
    "lib": [
      "esnext"
    ],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@happitime/shared-api": [
        "../../packages/shared-api/src/index.ts"
      ],
      "@happitime/shared-env": [
        "../../packages/shared-env/src/index.ts"
      ],
      "@happitime/shared-types": [
        "../../packages/shared-types/index.ts"
      ]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "react",
      "react-native",
      "react-native-screens"
    ]
  },
  "include": [
    "src",
    "App.tsx",
    "components",
    "constants",
    "hooks"
  ],
  "extends": "expo/tsconfig.base"
}
