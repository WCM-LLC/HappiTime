# ── Required ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternative to ANON_KEY (use one or the other):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated list of admin email addresses
ADMIN_EMAILS=

# ── Transactional email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=

# ── Billing / Stripe (server-only) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRODUCT_BASIC=
STRIPE_PRODUCT_FEATURED=
STRIPE_PRODUCT_PREMIUM=
STRIPE_WEBHOOK_SECRET=
# Comma-separated console origins allowed to create Checkout/Portal sessions:
APP_ALLOWED_ORIGINS=https://happitime-console.vercel.app,https://www.happitime.biz
# Optional second webhook secret, only if a second Stripe endpoint is configured:
# STRIPE_WEBHOOK_SECRET_THIN=

# ── Auth (optional debug) ─────────────────────────────────────────────────────
AUTH_DEBUG=false
NEXT_PUBLIC_AUTH_DEBUG=false
# NEXT_PUBLIC_CONSOLE_URL=https://happitime-console.vercel.app
# NEXT_PUBLIC_SITE_URL=

# ── Maps (optional) ──────────────────────────────────────────────────────────
# NEXT_PUBLIC_MAPS_PROVIDER=
# NEXT_PUBLIC_MAPS_API_KEY=
# NEXT_PUBLIC_MAPS_STYLE_ID=

# ── Event ingestion (optional) ────────────────────────────────────────────────
# EVENTS_INGEST_API_KEY=
# EVENTS_INGEST_RATE_LIMIT_PER_MIN=
# EVENTS_INGEST_MAX_BATCH=
# NEXT_PUBLIC_EVENTS_INGEST_URL=

# ── Search / recommendations (optional, stubs active until infra is wired) ────
# NEXT_PUBLIC_SEARCH_API_URL=
# NEXT_PUBLIC_RECOMMENDATIONS_API_URL=

# ── Push notifications (optional, stub until FCM/VAPID is wired) ─────────────
# NEXT_PUBLIC_WEB_PUSH_ENABLED=

# ── Media (optional) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_MEDIA_METADATA_TABLE=
# NEXT_PUBLIC_MEDIA_CDN_BASE_URL=
# NEXT_PUBLIC_MEDIA_PROVIDER=
# Cloudinary delete uses server-only signed requests. Set either CLOUDINARY_URL
# or the split API key/secret pair. Do not prefix these with NEXT_PUBLIC_.
# CLOUDINARY_URL=
# CLOUDINARY_CLOUD_NAME=dhucspghz
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Analytics / error reporting (optional) ───────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_PROVIDER=
# NEXT_PUBLIC_ANALYTICS_DEBUG=false
# NEXT_PUBLIC_ERROR_REPORTING_PROVIDER=

# ── AI Field Capture (/intake/capture) ───────────────────────────────────────
# Vision provider: 'gemini' (default, free tier) or 'anthropic'.
# INTAKE_VISION_PROVIDER=gemini
# Gemini: free tier covers 1,500 captures/day. Get a key at https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY=
# Anthropic: requires separate API billing at console.anthropic.com (NOT your Claude.ai plan).
# ANTHROPIC_API_KEY=
# Optional: override model. Defaults: gemini-2.5-flash / claude-sonnet-4-6
# INTAKE_MODEL=
# Owner-confirmation toggle. If unset, the switch in /intake/capture is disabled.
# Generate with: openssl rand -hex 32
# INTAKE_CONFIRM_SECRET=
# Resend API key for delivering the confirmation email. Without this, /api/intake/commit
# returns a claim_url you can copy to the owner manually.
# RESEND_API_KEY=
