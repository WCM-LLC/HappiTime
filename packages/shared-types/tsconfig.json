{
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "strict": true,
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "target": "ESNext",
    "esModuleInterop": true
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": ["dist", "node_modules"]
}
